// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEITUNG
  TRAINER
  GRUPPEN_VERWALTUNG
}

enum EventType {
  REGATTA
  VERANSTALTUNG
}

enum AnnouncementPriority {
  NIEDRIG
  MITTEL
  HOCH
}

enum AttendanceStatus {
  ANWESEND
  ABWESEND
}

model User {
  id             String                    @id @default(cuid())
  username       String                    @unique
  displayName    String
  role           Role
  passwordHash   String
  active         Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  lastLoginAt    DateTime?
  assignments    TrainingGroupAssignment[]
  createdEvents  CalendarEvent[]           @relation("EventCreator")
  participatingEvents CalendarEvent[]      @relation("EventTrainers")
  announcements  Announcement[]            @relation("AnnouncementCreator")
  attendances    AttendanceEntry[]         @relation("AttendanceCreator")
  attendanceLists AttendanceList[]         @relation("AttendanceListCreator")
  compensation   TrainerCompensation?
}

model TrainingGroup {
  id          String                    @id @default(cuid())
  name        String
  description String
  active      Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  assignments TrainingGroupAssignment[]
  athletes    Athlete[]
  attendance  AttendanceEntry[]
  attendanceLists AttendanceList[]
  calendarEvents CalendarEvent[]        @relation("EventGroups")
}

// n:m ist hier sinnvoll, weil ein Trainer mehrere Gruppen betreuen kann
// und Gruppen gleichzeitig mehreren Trainern zugeordnet werden können.
model TrainingGroupAssignment {
  id        String        @id @default(cuid())
  userId    String
  groupId   String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     TrainingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  type        EventType
  startDate   DateTime
  endDate     DateTime
  durationHours Decimal @default(1) @db.Decimal(6, 2)
  location    String
  description String
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation("EventCreator", fields: [createdById], references: [id], onDelete: Restrict)
  groups      TrainingGroup[] @relation("EventGroups")
  trainers    User[]     @relation("EventTrainers")
}

model TrainerCompensation {
  id           String   @id @default(cuid())
  userId       String   @unique
  hourlyRate   Decimal  @default(0) @db.Decimal(10, 2)
  totalPaid    Decimal  @default(0) @db.Decimal(12, 2)
  lastPayoutAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String
  priority    AnnouncementPriority
  validFrom   DateTime
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  archived    Boolean              @default(false)
  createdBy   User                 @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Restrict)
}

model Athlete {
  id        String                @id @default(cuid())
  name      String
  birthDate DateTime?
  active    Boolean               @default(true)
  groupId   String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  group     TrainingGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entries   AthleteTrainingEntry[]
  attendance AttendanceEntry[]
  attendanceListItems AttendanceListItem[]

  @@index([groupId])
}

model AttendanceList {
  id          String               @id @default(cuid())
  groupId     String
  date        DateTime
  title       String
  isFinalized Boolean              @default(false)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  group       TrainingGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User                 @relation("AttendanceListCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items       AttendanceListItem[]

  @@index([groupId, date])
}

model AttendanceListItem {
  id        String           @id @default(cuid())
  listId    String
  athleteId String
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  list      AttendanceList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  athlete   Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([listId, athleteId])
  @@index([athleteId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actorRole Role
  action    String
  targetType String
  targetId  String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}

model AttendanceEntry {
  id          String           @id @default(cuid())
  groupId     String
  athleteId   String
  date        DateTime
  status      AttendanceStatus
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  group       TrainingGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  athlete     Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("AttendanceCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([athleteId, date])
  @@index([groupId, date])
}

model AthleteTrainingEntry {
  id           String   @id @default(cuid())
  athleteId    String
  trainingDate DateTime
  result       String
  notes        String?
  createdAt    DateTime @default(now())
  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId, trainingDate])
}
